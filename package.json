{
  "name": "cvs-health-finance360",
  "version": "1.0.0",
  "description": "CVS Health Finance360 — AI-Powered Management Reporting Platform for CVS Health Corporation",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "clean": "node -e \"try { require('fs').rmSync('.next', { recursive: true, force: true }); } catch (_) {}\"",
    "dev:clean": "npm run clean && next dev -p 3001",
    "build": "prisma generate && next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "db:seed": "tsx prisma/seed.ts",
    "db:push": "npx prisma db push",
    "db:migrate": "npx prisma migrate deploy",
    "db:migrate:dev": "npx prisma migrate dev",
    "db:studio": "npx prisma studio",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.59",
    "@ai-sdk/react": "^3.0.118",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.4.2",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@tanstack/react-virtual": "^3.13.21",
    "ai": "^6.0.116",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.0.0",
    "date-fns": "^2.30.0",
    "dotenv": "^17.3.1",
    "framer-motion": "^10.16.5",
    "lucide-react": "^0.292.0",
    "mermaid": "^11.12.3",
    "next": "^14.0.0",
    "prisma": "^6.19.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "recharts": "^2.9.3",
    "remark-gfm": "^4.0.1",
    "rss-parser": "^3.13.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.0.0",
    "jsdom": "^27.0.1",
    "postcss": "^8.4.31",
    "tsx": "^4.21.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": "20.x"
  }
}

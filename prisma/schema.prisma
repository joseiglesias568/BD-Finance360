  companyId   Int
  type        String // "risk" | "opportunity"
  title       String
  probability String @default("") // "High" | "Medium" | "Low" | "Very High"
  impact      String @default("") // "$150-200M"
  mitigation  String @default("") // for risks
  action      String @default("") // for opportunities
  trend       String @default("") // "increasing" | "stable" | "decreasing"
  sortOrder   Int    @default(0)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("risk_opportunities")
}

// =============================================================================
// AI SEARCH / PERSONALIZED INSIGHTS
// =============================================================================

model PersonalizedInsight {
  id              Int    @id @default(autoincrement())
  companyId       Int
  title           String
  category        String
  insightLevel    String @default("L1") // "L1" (Facts) | "L2" (Variance) | "L3" (Forecast) | "L4" (What-If) | "L5" (Root Cause)
  metricId        String @default("") // Links to KPIDefinition label or driver metric
  kpiValue        String @default("")
  trendDirection  String @default("") // "up" | "down" | "flat"
  priority        String @default("medium") // "high" | "medium" | "low"
  summary         String @default("")
  confidenceScore Float  @default(0)
  consoleLink     String @default("")
  recommendations Json   @default("[]") // string[] or structured recommendations
  relatedDrivers  Json   @default("[]") // related driver info

  company    Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  commentary Commentary[]

  @@map("personalized_insights")
}

// =============================================================================
// COMMENTARY — Human-authored business context linked to AI insights
// =============================================================================

model Commentary {
  id              Int      @id @default(autoincrement())
  companyId       Int
  externalId      String   @default(uuid())

  // Content
  title           String
  content         String   // markdown-formatted rich text
  contentPlain    String   @default("")

  // Author metadata
  authorName      String   @default("Sarah Johnson")
  authorRole      String   @default("VP, Financial Planning & Analysis")

  // Classification
  category        String   // "Revenue & Market", "Financial Performance", etc.
  tags            Json     @default("[]")
  relatedKPIs     Json     @default("[]")
  relatedConsoles Json     @default("[]")
  relatedDrivers  Json     @default("[]")

  // Linkage to AI insights
  linkedInsightId Int?

  // Time context
  fiscalPeriod    String   @default("")
  periodType      String   @default("quarter")

  // Status & classification
  status          String   @default("published")
  priority        String   @default("medium")
  commentaryType  String   @default("analysis")

  // Driver-level linkage & AI aggregation
  driverId            Int?     // FK to ConsoleDriver for hierarchy placement
  aggregationLevel    String   @default("manual") // "driver" | "console" | "category" | "executive" | "manual"
  isAiGenerated       Boolean  @default(false)
  sourceCommentaryIds Json     @default("[]") // Int[] of child commentary IDs used in aggregation

  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  company       Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  linkedInsight PersonalizedInsight?  @relation(fields: [linkedInsightId], references: [id], onDelete: SetNull)
  driver        ConsoleDriver?       @relation(fields: [driverId], references: [id], onDelete: SetNull)

  @@unique([companyId, externalId])
  @@map("commentary")
}

// =============================================================================
// BUSINESS ARCHITECTURE — Semantic Model (recursive driver tree)
// =============================================================================

model BusinessConsole {
  id        Int    @id @default(autoincrement())
  companyId Int
  title     String // "North America Performance"
  category  String // "Revenue & Market"
  segment   String @default("") // "north-america", "international", etc.
  objective String @default("")

  company Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  drivers ConsoleDriver[]

  @@unique([companyId, title])
  @@map("business_consoles")
}

model ConsoleDriver {
  id               Int    @id @default(autoincrement())
  consoleId        Int
  parentDriverId   Int?   // null for top-level drivers (self-referential)
  name             String
  description      String @default("")
  causalityWeight  Float? // 0.0-1.0 weight of this driver's impact on parent
  impactDirection  String @default("") // "positive" | "negative" | "mixed"
  sortOrder        Int    @default(0)

  console  BusinessConsole @relation(fields: [consoleId], references: [id], onDelete: Cascade)
  parent   ConsoleDriver?  @relation("DriverHierarchy", fields: [parentDriverId], references: [id], onDelete: SetNull)
  children ConsoleDriver[] @relation("DriverHierarchy")
  metrics  DriverMetric[]

  // Cross-references (many-to-many via join table)
  crossReferencesFrom DriverCrossReference[] @relation("CrossRefFrom")
  crossReferencesTo   DriverCrossReference[] @relation("CrossRefTo")
  driverForecasts     DriverForecast[]
  commentary          Commentary[]

  @@map("console_drivers")
}

model DriverMetric {
  id           Int     @id @default(autoincrement())
  driverId     Int
  periodId     Int?    // nullable for current/static values
  name         String
  unit         String  // "currency" | "percent" | "count" | "ratio" | "time" | "score" | "index"
  currentValue String  @default("")
  target       String  @default("")
  frequency    String  @default("") // "quarterly" | "monthly" | "daily" | "weekly"
  direction    String  @default("") // "higher" | "lower" | "on_target"

  driver ConsoleDriver @relation(fields: [driverId], references: [id], onDelete: Cascade)
  period FiscalPeriod? @relation(fields: [periodId], references: [id], onDelete: SetNull)

  @@map("driver_metrics")
}

model DriverCrossReference {
  id             Int    @id @default(autoincrement())
  sourceDriverId Int
  targetDriverId Int
  relationship   String @default("") // Description of how they're related

  sourceDriver ConsoleDriver @relation("CrossRefFrom", fields: [sourceDriverId], references: [id], onDelete: Cascade)
  targetDriver ConsoleDriver @relation("CrossRefTo", fields: [targetDriverId], references: [id], onDelete: Cascade)

  @@unique([sourceDriverId, targetDriverId])
  @@map("driver_cross_references")
}

// =============================================================================
// LAYER 1: DATA INPUTS — Source system registry
// =============================================================================

model DataSource {
  id               Int    @id @default(autoincrement())
  companyId        Int
  externalId       String // "sap-erp", "salesforce-crm", "excel-treasury"
  name             String // "SAP S/4HANA"
  type             String // "ERP" | "CRM" | "Excel" | "3rd Party" | "API" | "Manual"
  category         String // "Financial" | "Operational" | "Market" | "HR" | "Digital"
  description      String @default("")
  connectionType   String @default("") // "Direct API" | "Batch ETL" | "File Upload" | "Streaming"
  refreshFrequency String @default("") // "Real-time" | "Daily" | "Weekly" | "Monthly"
  lastSyncAt       String @default("") // ISO date string
  status           String @default("active") // "active" | "degraded" | "error" | "inactive"
  recordCount      Int    @default(0)
  owner            String @default("") // "Finance IT" | "Data Engineering"

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  dataFlows DataFlow[]

  @@unique([companyId, externalId])
  @@map("data_sources")
}

// =============================================================================
// LAYER 2: FINANCE DATA LAKE — Data lineage, quality, and governance
// =============================================================================

model DataFlow {
  id               Int    @id @default(autoincrement())
  companyId        Int
  sourceId         Int
  targetLayer      String // "bronze" | "silver" | "gold"
  targetEntity     String // "financial_statements" | "kpi_values" | "segment_results" etc.
  transformations  Json   @default("[]") // string[] description of transforms
  lastRunAt        String @default("")
  lastRunStatus    String @default("success") // "success" | "warning" | "failed"
  recordsProcessed Int    @default(0)
  recordsRejected  Int    @default(0)
  avgLatencyMs     Int    @default(0)

  company       Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  source        DataSource         @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  qualityChecks DataQualityCheck[]

  @@map("data_flows")
}

model DataQualityCheck {
  id           Int    @id @default(autoincrement())
  companyId    Int
  flowId       Int?
  checkName    String // "Null Check - Revenue" | "Range Validation - Margin"
  checkType    String // "completeness" | "accuracy" | "timeliness" | "consistency" | "validity"
  targetEntity String // which DB table/entity this validates
  rule         String @default("") // "Revenue > 0 for all active periods"
  status       String // "pass" | "warn" | "fail"
  score        Float  @default(100) // 0-100 quality score
  lastRunAt    String @default("")
  failedRecords Int   @default(0)
  totalRecords  Int   @default(0)
  details      String @default("") // failure details

  company Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  flow    DataFlow? @relation(fields: [flowId], references: [id], onDelete: SetNull)

  @@map("data_quality_checks")
}

model MasterDataEntity {
  id              Int    @id @default(autoincrement())
  companyId       Int
  domain          String // "Chart of Accounts" | "Cost Centers" | "Store Master" | "Product Hierarchy"
  entityCount     Int    @default(0)
  lastUpdated     String @default("")
  steward         String @default("") // "Finance Ops" | "Store Operations"
  goldenRecordPct Float  @default(100) // % of records that are master-governed
  duplicateCount  Int    @default(0)
  status          String @default("active") // "active" | "under-review" | "stale"

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, domain])
  @@map("master_data_entities")
}

// =============================================================================
// LAYER 3: DATA & ANALYTICS PRODUCTS — ML Models, Forecasting, Anomaly Detection
// =============================================================================

model ForecastResult {
  id              Int      @id @default(autoincrement())
  companyId       Int
  metricName      String   // "Revenue" | "Operating Margin" | "Comp Store Sales" | "Store Count"
  periodLabel     String   // "Q2 FY26"
  modelType       String   // "ARIMA" | "Prophet" | "XGBoost" | "Ensemble"
  forecastValue   Float
  lowerBound      Float    // 90% CI lower
  upperBound      Float    // 90% CI upper
  actualValue     Float?   // null for future periods
  confidenceScore Float    @default(0.85) // 0-1
  mape            Float    @default(0) // Mean Absolute Percentage Error
  createdAt       DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, metricName, periodLabel, modelType])
  @@map("forecast_results")
}

model AnomalyDetection {
  id             Int    @id @default(autoincrement())
  companyId      Int
  metricName     String // "NA Comp Transactions" | "Mobile Order %"
  detectedAt     String // ISO date
  severity       String // "critical" | "warning" | "info"
  direction      String // "above_expected" | "below_expected"
  expectedValue  Float
  actualValue    Float
  deviationPct   Float  // how far off in percentage
  explanation    String @default("") // AI-generated explanation
  status         String @default("new") // "new" | "acknowledged" | "resolved" | "false-positive"
  relatedDrivers Json   @default("[]") // string[] of driver names that likely caused this

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("anomaly_detections")
}

// =============================================================================
// LAYER 4: EPM — In-Cycle Estimates for current period tracking
// =============================================================================

model InCycleEstimate {
  id                Int    @id @default(autoincrement())
  companyId         Int
  periodLabel       String // "Q2 FY26"
  metricName        String // "Revenue" | "Operating Income" | "Comp Store Sales"
  mtdActual         Float  // month-to-date actual
  qtdActual         Float  // quarter-to-date actual
  flashEstimate     Float  // extrapolated quarter-end estimate
  forecastValue     Float  // official forecast
  budgetValue       Float  // budget/plan value
  priorYearActual   Float  // prior year same period
  daysThroughPeriod Int    // e.g., 47 out of 91
  totalDaysInPeriod Int    @default(91)
  lastUpdated       String @default("")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, periodLabel, metricName])
  @@map("in_cycle_estimates")
}

// =============================================================================
// EPM Configuration & Driver-Based Planning

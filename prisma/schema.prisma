// =============================================================================
// Delta Finance360 AI-Powered Management Reporting — Database Schema
// Prisma + Neon PostgreSQL
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// CORE / MULTI-TENANT
// =============================================================================

model Company {
  id              Int      @id @default(autoincrement())
  name            String   // "Delta Air Lines, Inc."
  ticker          String   // "DAL"
  platformName    String   // "Delta Finance360"
  tagline         String   @default("")
  subtitle        String   @default("")
  logoPath        String   @default("")
  logoAlt         String   @default("")
  copyrightHolder String   @default("")
  copyrightYear   Int      @default(2026)
  poweredBy       String   @default("")
  ceo             String   @default("")
  cfo             String   @default("")
  fiscalYearEnd   String   @default("") // "September 30"
  industry        String   @default("")
  headquarters    String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  brandColors            BrandColors?
  fiscalPeriods          FiscalPeriod[]
  businessSegments       BusinessSegment[]
  financialStatements    FinancialStatement[]
  revenueBridgeItems     RevenueBridgeItem[]
  financialRatios        FinancialRatio[]
  workingCapitalMetrics  WorkingCapitalMetric[]
  kpiDefinitions         KPIDefinition[]
  locations              Location[]
  supplyChainMetrics     SupplyChainMetric[]
  digitalMetrics         DigitalMetric[]
  industryKPIs           IndustryKPI[]
  strategicInitiatives   StrategicInitiative[]
  riskItems              RiskItem[]
  forwardOutlook         ForwardOutlook[]
  keyOpportunities       KeyOpportunity[]
  marketData             MarketData[]
  competitors            Competitor[]
  regionalBreakdown      RegionalBreakdown[]
  scenarioLevers         ScenarioLever[]
  preBuiltScenarios      PreBuiltScenario[]
  alertTemplates         AlertTemplate[]
  reportTemplates        ReportTemplate[]
  closeTasks             CloseTask[]
  trialBalanceItems      TrialBalanceItem[]
  personalizedInsights   PersonalizedInsight[]
  executiveNarratives    ExecutiveNarrative[]
  businessPillars        BusinessPillar[]
  criticalActions        CriticalAction[]
  forwardInsights        ForwardInsight[]
  executiveBriefings     ExecutiveBriefing[]
  businessInsights       BusinessInsight[]
  riskOpportunities      RiskOpportunity[]
  businessConsoles       BusinessConsole[]
  operationsSummary      OperationsSummary?
  scenarioBaseline       ScenarioBaseline?
  journalEntryStats      JournalEntryStats?

  // Layer 1+2: Data Platform
  dataSources            DataSource[]
  dataFlows              DataFlow[]
  dataQualityChecks      DataQualityCheck[]
  masterDataEntities     MasterDataEntity[]

  // Layer 3: Analytics Products
  forecastResults        ForecastResult[]
  anomalyDetections      AnomalyDetection[]

  // Layer 4: EPM
  inCycleEstimates       InCycleEstimate[]
  planningMilestones     PlanningMilestone[]
  platformConfigs        PlatformConfig[]
  driverForecasts        DriverForecast[]

  // Commentary
  commentary             Commentary[]

  // Enrichment Layer: Dimensional Data
  monthlyFinancials             MonthlyFinancial[]
  regionalPerformance           RegionalPerformance[]
  productCategoryPerformance    ProductCategoryPerformance[]
  daypartPerformance            DaypartPerformance[]
  costDriverDetails             CostDriverDetail[]
  varianceExplanations          VarianceExplanation[]
  weeklySnapshots               WeeklySnapshot[]
  elasticityFactors             ElasticityFactor[]
  competitorQuarterlyMetrics    CompetitorQuarterlyMetric[]
  storeClusters                 StoreCluster[]

  // Platform Enhancement Layer
  storeFormatMix               StoreFormatMix[]
  strategyExecution            StrategyExecution[]
  commodityPrices              CommodityPrice[]
  fxImpacts                    FXImpact[]
  laborMetrics                 LaborMetric[]
  customerSatisfaction         CustomerSatisfaction[]
  promotionalCalendar          PromotionalCalendar[]
  storeRenovations             StoreRenovation[]

  @@map("companies")
}

model BrandColors {
  id           Int    @id @default(autoincrement())
  companyId    Int    @unique
  primary      String // "#006241"
  primaryDark  String // "#1E3932"
  primaryLight String // "#D4E9E2"
  primaryAlt   String // "#00704A"
  navBg        String @default("")
  navBgLight   String @default("")
  accent       String @default("")
  success      String @default("")
  warning      String @default("")
  danger       String @default("")
  info         String @default("")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("brand_colors")
}

// =============================================================================
// TIME DIMENSION
// =============================================================================

model FiscalPeriod {
  id        Int    @id @default(autoincrement())
  companyId Int
  type      String // "quarter" | "annual"
  label     String // "Q4 FY25" or "FY25"
  year      Int    // 2025
  quarter   Int?   // 1-4, null for annual
  startDate String @default("")
  endDate   String @default("")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Fact tables linked to this period
  quarterlyResults      QuarterlyResult?
  segmentResults        SegmentResult[]
  financialStatements   FinancialStatement[]
  revenueBridgeItems    RevenueBridgeItem[]
  financialRatios       FinancialRatio[]
  workingCapitalMetrics WorkingCapitalMetric[]
  kpiValues             KPIValue[]
  locationMetrics       LocationMetric[]
  supplyChainMetrics    SupplyChainMetric[]
  driverMetrics         DriverMetric[]
  marketData            MarketData[]
  regionalBreakdown     RegionalBreakdown[]
  forwardOutlook        ForwardOutlook[]

  // Enrichment Layer
  monthlyFinancials          MonthlyFinancial[]
  regionalPerformance        RegionalPerformance[]
  productCategoryPerformance ProductCategoryPerformance[]
  daypartPerformance         DaypartPerformance[]
  costDriverDetails          CostDriverDetail[]
  varianceExplanations       VarianceExplanation[]
  competitorQuarterlyMetrics CompetitorQuarterlyMetric[]
  storeClusters              StoreCluster[]

  // Platform Enhancement Layer
  storeFormatMix             StoreFormatMix[]
  fxImpacts                  FXImpact[]
  laborMetrics               LaborMetric[]
  customerSatisfaction       CustomerSatisfaction[]

  @@unique([companyId, label])
  @@map("fiscal_periods")
}

// =============================================================================
// FINANCIAL DATA
// =============================================================================

model QuarterlyResult {
  id              Int    @id @default(autoincrement())
  periodId        Int    @unique
  revenue         Float  // in billions
  revenueYoY      Float  // percentage
  operatingIncome Float
  operatingMargin Float
  eps             Float
  compStoreSales  Float
  netNewStores    Int?

  period FiscalPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@map("quarterly_results")
}

model BusinessSegment {
  id             Int    @id @default(autoincrement())
  companyId      Int
  name           String // "North America"
  description    String @default("")
  revenuePercent Float  // percent of total

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  segmentResults SegmentResult[]

  @@unique([companyId, name])
  @@map("business_segments")
}

model SegmentResult {
  id              Int    @id @default(autoincrement())
  segmentId       Int
  periodId        Int
  revenue         Float  // in billions
  yoyChange       Float  // percentage
  operatingMargin Float?

  segment BusinessSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  period  FiscalPeriod    @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([segmentId, periodId])
  @@map("segment_results")
}

model FinancialStatement {
  id              Int    @id @default(autoincrement())
  companyId       Int
  periodId        Int
  lineItem        String // "revenue", "cogs", "grossProfit", "operatingExpenses", "operatingIncome", "netIncome"
  label           String // Human-readable: "Net Revenues"
  actual          Float  // in millions
  plan            Float
  priorYear       Float
  variance        Float
  variancePercent Float

  company Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  period  FiscalPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([companyId, periodId, lineItem])
  @@map("financial_statements")
}

model RevenueBridgeItem {
  id          Int    @id @default(autoincrement())
  companyId   Int
  periodId    Int
  label       String // "Comp Store Sales"
  impact      Float  // in millions, positive = favorable
  description String @default("")
  category    String // "volume" | "mix" | "pricing" | "cost" | "fx" | "other"
  sortOrder   Int    @default(0)

  company Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  period  FiscalPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@map("revenue_bridge_items")
}

model FinancialRatio {
  id        Int    @id @default(autoincrement())
  companyId Int
  periodId  Int
  name      String // "currentRatio", "debtToEquity", etc.
  value     Float
  benchmark Float?

  company Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  period  FiscalPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([companyId, periodId, name])
  @@map("financial_ratios")
}

model WorkingCapitalMetric {
  id       Int    @id @default(autoincrement())
  companyId Int
  periodId Int
  name     String // "dso", "inventoryDays", "dpo"
  actual   Float
  target   Float

  company Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  period  FiscalPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([companyId, periodId, name])
  @@map("working_capital_metrics")
}

// =============================================================================
// KPIs — Core value-add for forecast vs actuals
// =============================================================================

model KPIDefinition {
  id          Int    @id @default(autoincrement())
  companyId   Int
  category    String // "primary" | "operational" | "digital" | "financial"
  label       String // "Global Revenue"
  unit        String // "%", "B", "M", etc.
  description String @default("")
  formula     String @default("") // e.g., "comp_transactions + comp_ticket"
  dataSource  String @default("") // e.g., "POS System", "Rewards Platform"
  sortOrder   Int    @default(0)

  company Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  values  KPIValue[]

  @@unique([companyId, label])
  @@map("kpi_definitions")
}

model KPIValue {
  id              Int     @id @default(autoincrement())
  kpiDefinitionId Int
  periodId        Int
  dataType        String  // "actual" | "forecast" | "budget" | "plan"
  value           String  // String to handle both numbers and formatted values like "40,990"
  target          String? // Same — could be "41,500" or "2%"
  trend           String  // "up" | "down" | "flat"
  trendValue      String  @default("") // "+5.0% YoY"
  status          String  // "good" | "warning" | "critical"

  kpiDefinition KPIDefinition @relation(fields: [kpiDefinitionId], references: [id], onDelete: Cascade)
  period        FiscalPeriod  @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([kpiDefinitionId, periodId, dataType])
  @@map("kpi_values")
}

// =============================================================================
// OPERATIONS
// =============================================================================

model OperationsSummary {
  id                    Int   @id @default(autoincrement())
  companyId             Int   @unique
  totalLocations        Int
  locationGrowth        Int   // net new
  locationGrowthPercent Float

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("operations_summary")
}

model Location {
  id        Int    @id @default(autoincrement())
  companyId Int
  name      String // "Kent Roasting Plant"
  type      String // "Roasting Facility", "Distribution Center", etc.
  region    String @default("")
  country   String @default("")
  format    String @default("") // "Traditional", "Drive-Thru Only", etc.
  ownership String @default("") // "company-operated" | "licensed"

  company Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  metrics LocationMetric[]

  @@map("locations")
}

model LocationMetric {
  id         Int     @id @default(autoincrement())
  locationId Int
  periodId   Int?    // nullable for current/static metrics
  label      String
  value      String  // String to handle mixed types
  target     String?
  status     String  // "good" | "warning" | "critical"

  location Location      @relation(fields: [locationId], references: [id], onDelete: Cascade)
  period   FiscalPeriod? @relation(fields: [periodId], references: [id], onDelete: SetNull)

  @@map("location_metrics")
}

model SupplyChainMetric {
  id        Int     @id @default(autoincrement())
  companyId Int
  periodId  Int?
  label     String
  value     String
  target    String
  trend     String  // "up" | "down" | "flat"
  status    String  // "good" | "warning" | "critical"

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  period  FiscalPeriod? @relation(fields: [periodId], references: [id], onDelete: SetNull)

  @@map("supply_chain_metrics")
}

model DigitalMetric {
  id          Int    @id @default(autoincrement())
  companyId   Int
  label       String
  value       String
  description String @default("")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("digital_metrics")
}

model IndustryKPI {
  id          Int     @id @default(autoincrement())
  companyId   Int
  label       String
  value       String
  target      String?
  benchmark   String?
  description String  @default("")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("industry_kpis")
}

// =============================================================================
// STRATEGIC
// =============================================================================

model StrategicInitiative {
  id          Int    @id @default(autoincrement())
  companyId   Int
  externalId  String // original "green-apron" style id
  name        String
  description String @default("")
  status      String // "on-track" | "at-risk" | "behind" | "completed"
  budget      Float  // millions
  spent       Float  // millions
  progress    Int    // 0-100

  company    Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  milestones InitiativeMilestone[]
  kpis       InitiativeKPI[]

  @@unique([companyId, externalId])
  @@map("strategic_initiatives")
}

model InitiativeMilestone {
  id           Int    @id @default(autoincrement())
  initiativeId Int
  name         String
  date         String
  status       String // "completed" | "in-progress" | "planned"

  initiative StrategicInitiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)

  @@map("initiative_milestones")
}

model InitiativeKPI {
  id           Int    @id @default(autoincrement())
  initiativeId Int
  label        String
  target       String
  actual       String
  status       String // "good" | "warning" | "critical"

  initiative StrategicInitiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)

  @@map("initiative_kpis")
}

model RiskItem {
  id          Int    @id @default(autoincrement())
  companyId   Int
  externalId  String // original id
  category    String
  title       String
  description String @default("")
  severity    String // "high" | "medium" | "low"
  likelihood  String // "high" | "medium" | "low"
  impact      String @default("")
  mitigation  String @default("")
  owner       String @default("")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, externalId])
  @@map("risk_items")
}

model ForwardOutlook {
  id             Int    @id @default(autoincrement())
  companyId      Int
  periodId       Int?
  period         String // "Q1 FY26" etc.
  revenueForecast Float
  revenuePlan    Float
  marginForecast Float
  marginPlan     Float
  keyAssumptions Json   @default("[]") // string[]

  company    Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fiscalPeriod FiscalPeriod? @relation(fields: [periodId], references: [id], onDelete: SetNull)

  @@map("forward_outlook")
}

model KeyOpportunity {
  id            Int    @id @default(autoincrement())
  companyId     Int
  title         String
  revenueImpact String
  description   String @default("")
  timeline      String @default("")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("key_opportunities")
}

// =============================================================================
// MARKET & COMPETITIVE INTELLIGENCE
// =============================================================================

model MarketData {
  id                 Int    @id @default(autoincrement())
  companyId          Int
  periodId           Int?
  totalMarketSize    String // "$100B"
  companyMarketShare Float
  marketShareTarget  Float
  marketShareYoY     Float
  segmentGrowth      Float
  marketDrivers      Json   @default("[]") // string[]
  marketChallenges   Json   @default("[]") // string[]

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  period  FiscalPeriod? @relation(fields: [periodId], references: [id], onDelete: SetNull)

  @@map("market_data")
}

model Competitor {
  id          Int    @id @default(autoincrement())
  companyId   Int
  name        String
  marketShare Float
  yoyChange   Float
  strengths   Json   @default("[]") // string[]

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@map("competitors")
}

model RegionalBreakdown {
  id         Int    @id @default(autoincrement())
  companyId  Int
  periodId   Int?
  region     String
  revenue    Float
  growth     Float
  keyInsight String @default("")

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  period  FiscalPeriod? @relation(fields: [periodId], references: [id], onDelete: SetNull)

  @@map("regional_breakdown")
}

// =============================================================================
// SCENARIOS
// =============================================================================

model ScenarioBaseline {
  id               Int   @id @default(autoincrement())
  companyId        Int   @unique
  baselineRevenue  Float // billions
  baselineMargin   Float // percent
  detailedBaseline Json? // Full P&L structure: segments, COGS, OpEx, tax rate, sensitivity

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("scenario_baselines")
}

model ScenarioLever {
  id          Int    @id @default(autoincrement())
  companyId   Int
  externalId  String // "leasing-growth"
  name        String
  category    String
  min         Float
  max         Float
  defaultVal  Float
  step        Float
  unit        String // "%", "$M", etc.
  description String @default("")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, externalId])
  @@map("scenario_levers")
}

model PreBuiltScenario {
  id             Int    @id @default(autoincrement())
  companyId      Int
  externalId     String // "global-tariff-escalation"
  name           String
  description    String @default("")
  icon           String @default("")
  confidence     Int    // 0-100
  revenueImpact  Float  // millions
  marginImpact   Float  // basis points
  keyAssumptions Json   @default("[]") // string[]
  leverSettings  Json   @default("{}") // Record<string, number>

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, externalId])
  @@map("pre_built_scenarios")
}

// =============================================================================
// ALERTS
// =============================================================================

model AlertTemplate {
  id               Int    @id @default(autoincrement())
  companyId        Int
  externalId       String
  title            String
  category         String
  metricId         String @default("") // Links to KPIDefinition label or driver metric
  threshold        String
  severity         String // "critical" | "warning" | "info"
  description      String @default("")
  suggestedActions Json   @default("[]") // string[]
  alertType        String @default("threshold") // "threshold" | "anomaly" | "forecast" | "trend"
  frequency        String @default("weekly")    // "realtime" | "hourly" | "daily" | "weekly" | "monthly"
  conditionPrefix  String @default("")          // e.g., "Falls below", "Exceeds", "Predicted to reach"

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, externalId])
  @@map("alert_templates")
}

// =============================================================================
// REPORTS
// =============================================================================

model ReportTemplate {
  id            Int      @id @default(autoincrement())
  companyId     Int
  externalId    String
  name          String
  category      String
  frequency     String
  description   String   @default("")
  department    String   @default("")
  format        String   @default("")
  owner         String   @default("")
  rating        Float    @default(4.0)
  views         Int      @default(0)
  isNew         Boolean  @default(false)
  isTrending    Boolean  @default(false)
  lastGenerated String?

  // Business alignment — connects reports to console architecture
  relatedConsoleId String?              // slug of parent console
  relatedReportIds Json     @default("[]") // string[] of sibling report externalIds
  dataSource       String   @default("")   // 'POS System', 'SAP S/4HANA', etc.
  accessLevel      String   @default("All Finance")
  audience         Json     @default("[]") // string[] of persona labels
  tags             Json     @default("[]") // string[] of searchable tags

  // Detail page content
  executiveSummary String   @default("")   // 2-3 sentence summary
  aiInsight        String   @default("")   // AI-generated latest finding
  recommendations  Json     @default("[]") // string[]
  keyMetrics       Json     @default("[]") // ReportKeyMetric[]
  chartData        Json     @default("[]") // ReportChartConfig[]
  tableData        Json?                   // ReportTableData (optional)

  // Scheduling
  nextUpdate       String   @default("")   // 'Every Monday 6:00 AM' or 'Mar 15, 2026'

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, externalId])
  @@map("report_templates")
}

// =============================================================================
// MONTH-END CLOSE
// =============================================================================

model CloseTask {
  id         Int    @id @default(autoincrement())
  companyId  Int
  externalId String
  phase      String
  name       String
  status     String // "completed" | "in-progress" | "pending" | "blocked"
  owner      String @default("")
  dueDate    String @default("")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, externalId])
  @@map("close_tasks")
}

model JournalEntryStats {
  id          Int   @id @default(autoincrement())
  companyId   Int   @unique
  total       Int
  totalAmount Float // millions
  automated   Int
  manual      Int

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("journal_entry_stats")
}

model TrialBalanceItem {
  id         Int    @id @default(autoincrement())
  companyId  Int
  label      String
  actual     Float
  priorMonth Float
  budget     Float

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("trial_balance_items")
}

// =============================================================================
// EXECUTIVE SUMMARY & MONTHLY REPORT DATA
// =============================================================================

model ExecutiveNarrative {
  id               Int    @id @default(autoincrement())
  companyId        Int
  periodLabel      String // "Q4 FY25"
  overallStatus    String // "Recovering" | "Growing" | "Declining"
  statusColor      String // "green" | "yellow" | "red"
  narrative        String // Long-form narrative text
  keyAchievements  Json   @default("[]") // string[]
  concerns         Json   @default("[]") // string[]

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, periodLabel])
  @@map("executive_narratives")
}

model BusinessPillar {
  id              Int    @id @default(autoincrement())
  companyId       Int
  periodLabel     String // "Q4 FY25"
  externalId      String // "commercial" | "operational" | "financial" | "risk"
  label           String // "Commercial Performance"
  value           String // "$9.6B"
  change          Float  // 5.0
  target          String // "$9.4B"
  status          String // "above" | "below" | "on-track"
  color           String // "green" | "red" | "yellow"
  keyInsight      String @default("")
  actionRequired  Boolean @default(false)
  metrics         Json   @default("[]") // Array of { label, value, change, vsTarget }
  forecast        String @default("") // forecast text for exec summary
  sparkline       Json   @default("[]") // number[] for sparkline chart
  subMetrics      Json   @default("[]") // Array of { name, value } for exec summary detail
  sortOrder       Int    @default(0)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, periodLabel, externalId])
  @@map("business_pillars")
}

model CriticalAction {
  id              Int    @id @default(autoincrement())
  companyId       Int
  title           String
  priority        String // "high" | "medium" | "low" | "critical"
  urgency         String // "immediate" | "urgent" | "planned" | "critical"
  owner           String
  dueDate         String
  description     String @default("")
  financialImpact String @default("")
  riskLevel       String @default("")
  status          String @default("pending") // "pending" | "in-progress" | "in-review" | "completed"
  category        String @default("") // "Digital" | "Strategic" | "Commercial" | "Financial"
  businessOutcome String @default("") // "Commercial" | "Operational" | "Financial" | "Risk"
  impact          String @default("") // Short impact description
  riskAssessment  String @default("")
  stakeholders    Json   @default("[]") // string[]
  dependencies    Json   @default("[]") // string[]
  sortOrder       Int    @default(0)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("critical_actions")
}

model ForwardInsight {

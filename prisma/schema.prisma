  title      String
  insight    String @default("")
  impact     String @default("")
  timeframe  String @default("")
  confidence String @default("")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("forward_insights")
}

model ExecutiveBriefing {
  id              Int    @id @default(autoincrement())
  companyId       Int
  periodLabel     String // "Q4 FY25"
  summary         String
  keyHighlights   Json   @default("[]") // Array of { type, text }
  recommendations Json   @default("[]") // string[]

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, periodLabel])
  @@map("executive_briefings")
}

model BusinessInsight {
  id              Int    @id @default(autoincrement())
  companyId       Int
  category        String // "Comp Store Sales", "Store Portfolio", etc.
  businessOutcome String // "Commercial" | "Operational" | "Financial" | "Risk"
  title           String
  metric          String @default("")
  change          Float  @default(0)
  status          String @default("medium") // "low" | "medium" | "high" | "critical"
  insight         String @default("")
  drivers         Json   @default("[]") // string[]
  actions         Json   @default("[]") // string[]
  relatedMetrics  Json   @default("{}") // Record<string, string>
  sortOrder       Int    @default(0)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)


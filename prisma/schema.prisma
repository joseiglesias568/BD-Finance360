}

model PlatformConfig {
  id        Int    @id @default(autoincrement())
  companyId Int
  module    String // "forecasting", "in-cycle", "bridge", "simulation", "planning"
  key       String // "mape_threshold_good", "status_at_risk_threshold"
  value     String // stored as string, parsed by consumer
  type      String @default("number") // "number", "string", "json", "boolean"

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, module, key])
  @@map("platform_configs")
}

model DriverForecast {
  id             Int    @id @default(autoincrement())
  companyId      Int
  driverId       Int
  metricName     String // "Comparable Transactions", "Average Ticket"
  periodLabel    String // "Q2 FY26"
  forecastValue  Float
  actualValue    Float?
  budgetValue    Float?
  priorYearValue Float?
  elasticity     Float? // impact multiplier: each 1 unit change = $XM revenue
  elasticityUnit String @default("$M") // "$M", "bps", "%"

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  driver  ConsoleDriver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@map("driver_forecasts")
}

// =============================================================================
// ENRICHMENT LAYER: Dimensional Data for Rich AI Analysis
// =============================================================================

// Monthly P&L by segment — enables month-over-month analysis
model MonthlyFinancial {
  id               Int    @id @default(autoincrement())
  companyId        Int
  periodId         Int    // FK to quarter
  month            Int    // 1, 2, 3 within the quarter
  monthLabel       String // "Oct 2024", "Nov 2024"
  segment          String // "North America" | "International" | "Channel Development" | "Consolidated"
  revenue          Float  // millions
  cogs             Float  // millions
  grossProfit      Float  // millions
  storeOpex        Float  // millions
  otherOpex        Float  // millions
  operatingIncome  Float  // millions
  compStoreSales   Float? // percentage
  transactions     Float? // millions
  averageTicket    Float? // dollars

  company Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  period  FiscalPeriod  @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([companyId, periodId, month, segment])
  @@map("monthly_financials")
}

// Regional performance — enables geographic drill-down
model RegionalPerformance {
  id               Int    @id @default(autoincrement())
  companyId        Int
  periodId         Int
  region           String // "US - West", "US - Northeast", "China - Tier 1", "Japan", "UK", etc.
  storeCount       Int
  revenue          Float  // millions
  revenueYoY       Float  // percentage
  compStoreSales   Float  // percentage
  compTransactions Float  // percentage
  averageTicket    Float  // dollars
  operatingMargin  Float  // percentage
  rewardsMemberPct Float? // percentage of transactions from Rewards
  mobileOrderPct   Float? // percentage of transactions via mobile
  newStores        Int?
  closedStores     Int?

  company Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  period  FiscalPeriod  @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([companyId, periodId, region])
  @@map("regional_performance")
}

// Product category performance — enables product mix analysis
model ProductCategoryPerformance {
  id                Int    @id @default(autoincrement())
  companyId         Int
  periodId          Int
  category          String // "Espresso Beverages", "Cold Beverages", "Refreshers & Tea", "Food", "Packaged & Other"
  segment           String // "North America" | "International" | "Consolidated"
  revenue           Float  // millions
  revenueYoY        Float  // percentage
  mixPercent        Float  // percentage of total segment revenue
  mixChange         Float  // change in mix percentage YoY (bps)
  averageTicket     Float  // dollars
  grossMarginPct    Float  // percentage
  customizationRate Float? // percentage of orders with add-ons
  unitsPerTransaction Float? // items per transaction

  company Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  period  FiscalPeriod  @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([companyId, periodId, category, segment])
  @@map("product_category_performance")
}

// Daypart performance — enables intra-day analysis
model DaypartPerformance {
  id                Int    @id @default(autoincrement())
  companyId         Int
  periodId          Int
  daypart           String // "Morning (5-11am)", "Midday (11am-2pm)", "Afternoon (2-5pm)", "Evening (5-Close)"
  segment           String // "North America" | "International" | "Consolidated"
  transactionPct    Float  // percentage of daily transactions
  revenuePct        Float  // percentage of daily revenue
  compSales         Float  // comp sales growth for this daypart
  averageTicket     Float  // dollars
  laborCostPct      Float  // labor as % of daypart revenue
  throughputMinutes Float? // average service time in minutes
  foodAttachRate    Float? // percentage of transactions with food item

  company Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  period  FiscalPeriod  @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([companyId, periodId, daypart, segment])
  @@map("daypart_performance")
}

// Cost driver decomposition — enables cost analysis
model CostDriverDetail {
  id               Int    @id @default(autoincrement())
  companyId        Int
  periodId         Int
  segment          String // "North America" | "International" | "Channel Development" | "Consolidated"
  costCategory     String // "COGS" | "Store Operating Expenses" | "G&A" | "Depreciation" | "Restructuring"
  costSubcategory  String // e.g., "Green Coffee", "Dairy & Alternatives", "Store Labor", "Rent & Occupancy"
  amount           Float  // millions
  percentOfRevenue Float  // percentage
  yoyChange        Float  // percentage change
  budget           Float  // millions
  varianceToBudget Float  // millions (favorable = positive)
  driver           String @default("") // explanation: "Commodity inflation", "Wage increases", etc.

  company Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  period  FiscalPeriod  @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([companyId, periodId, segment, costCategory, costSubcategory])
  @@map("cost_driver_details")
}

// Pre-computed variance explanations — enables "why" analysis
model VarianceExplanation {
  id              Int    @id @default(autoincrement())
  companyId       Int
  periodId        Int
  metricName      String // "Revenue", "Operating Margin", "Comp Store Sales", "EPS"
  varianceType    String // "actual_vs_plan" | "actual_vs_prior_year" | "actual_vs_forecast" | "sequential"
  totalVariance   Float  // the total variance amount
  totalVarianceUnit String // "$M" | "bps" | "%" | "per share"
  driverBreakdown Json   // Array of { driver, impact, impactUnit, explanation, confidence }
  narrative       String // AI-readable narrative explaining the variance
  recommendations Json   @default("[]") // string[] of recommended actions

  company Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  period  FiscalPeriod  @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([companyId, periodId, metricName, varianceType])
  @@map("variance_explanations")
}

// Weekly KPI snapshots — enables trend analysis at higher granularity
model WeeklySnapshot {
  id            Int    @id @default(autoincrement())
  companyId     Int
  weekNumber    Int    // 1-52
  weekLabel     String // "W1 Q2 FY26" or "Jan 6-12, 2026"
  weekStartDate String // ISO date
  metricName    String // "Revenue Run Rate", "Comp Sales Trend", "Mobile Order %", etc.
  value         Float
  priorWeek     Float?
  weekOverWeek  Float? // % change
  yoyValue      Float? // same week prior year
  yoyChange     Float? // % change vs prior year
  status        String @default("on_track") // "on_track" | "watch" | "at_risk" | "ahead"

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, weekLabel, metricName])
  @@map("weekly_snapshots")
}

// Elasticity factors — enables "what if" sensitivity analysis
model ElasticityFactor {
  id             Int    @id @default(autoincrement())
  companyId      Int
  driverMetric   String // "Comp Transactions", "Average Ticket", "Coffee Cost per Lb"
  impactedMetric String // "Revenue", "Operating Margin", "EPS"
  elasticity     Float  // e.g., 1% change in driver = X change in impacted
  elasticityUnit String // "$M", "bps", "cents"
  direction      String // "positive" (driver up → metric up) | "negative" (driver up → metric down)
  confidence     Float  // 0-1
  description    String @default("") // "Each 1% increase in comp transactions drives ~$XM in revenue"
  segment        String @default("Consolidated") // can be segment-specific

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, driverMetric, impactedMetric, segment])
  @@map("elasticity_factors")
}

// Competitor quarterly metrics — enables competitive benchmarking over time
model CompetitorQuarterlyMetric {
  id             Int    @id @default(autoincrement())
  companyId      Int
  periodId       Int
  competitorName String // "Dutch Bros", "Dunkin'", "Luckin Coffee", "McDonald's McCafé"
  metricName     String // "Revenue", "Store Count", "Comp Sales", "Market Share"
  value          Float
  unit           String // "$B", "count", "%"
  yoyChange      Float? // percentage

  company Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  period  FiscalPeriod  @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([companyId, periodId, competitorName, metricName])
  @@map("competitor_quarterly_metrics")
}

// Store cluster/cohort analysis — enables portfolio analysis
model StoreCluster {
  id               Int    @id @default(autoincrement())
  companyId        Int
  periodId         Int
  clusterName      String // "High-Volume Urban", "Drive-Thru Suburban", "Licensed Airport", "New (<1yr)", etc.
  storeCount       Int
  pctOfPortfolio   Float  // percentage of total stores
  avgRevenue       Float  // average annual revenue per store ($K)
  avgTicket        Float  // dollars
  avgDailyTxns     Int    // average daily transactions
  compSales        Float  // comp sales growth %
  operatingMargin  Float  // percentage
  rewardsPct       Float  // percentage of transactions from Rewards members
  mobileOrderPct   Float  // percentage mobile order
  avgDriveThruTime Float? // minutes (only for DT stores)
  laborCostPct     Float  // labor as % of revenue
  fourWallROI      Float? // store-level return on investment %

  company Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  period  FiscalPeriod  @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([companyId, periodId, clusterName])
  @@map("store_clusters")
}

// =============================================================================
// PLATFORM ENHANCEMENT LAYER
// =============================================================================

model StoreFormatMix {
  id             Int    @id @default(autoincrement())
  companyId      Int
  periodId       Int
  segment        String // "North America" | "International" | "Consolidated"
  format         String // "Company-Operated" | "Licensed" | "Drive-Thru" | "Reserve" | "Delivery-Only"
  storeCount     Int
  pctOfTotal     Float  // percentage of segment total
  avgRevenue     Float  // $K annual per store
  yoyGrowth      Float  // %
  compSales      Float? // %

  company Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  period  FiscalPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([companyId, periodId, segment, format])
  @@map("store_format_mix")
}

model StrategyExecution {
  id           Int    @id @default(autoincrement())
  companyId    Int
  pillar       String // "Morning Coffee Ritual" | "Afternoon Experience" | "Barista Culture" | "Store Design" | "Brand Communication"
  kpiName      String
  baseline     Float
  target       Float
  current      Float
  unit         String // "%" | "min" | "$" | "score" | "count"
  status       String // "on-track" | "at-risk" | "behind" | "ahead"
  quarterLabel String // "Q2 FY26"
  commentary   String @default("")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, pillar, kpiName, quarterLabel])
  @@map("strategy_execution")
}

model CommodityPrice {
  id             Int    @id @default(autoincrement())
  companyId      Int
  commodity      String // "Arabica Coffee" | "Robusta Coffee" | "Dairy" | "Sugar" | "Vanilla" | "Paper/Packaging"
  periodLabel    String // "Q2 FY26"
  spotPrice      Float
  hedgedPrice    Float?
  priorYearPrice Float
  unit           String // "$/lb" | "$/gal" | "$/ton"
  hedgeCoverage  Float? // % of next 12 months hedged
  yoyChange      Float  // %
  forecastNext   Float? // forecasted next quarter

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, commodity, periodLabel])
  @@map("commodity_prices")
}

model FXImpact {
  id              Int    @id @default(autoincrement())
  companyId       Int
  periodId        Int
  currencyPair    String // "CNY/USD" | "JPY/USD" | "GBP/USD" | "CAD/USD" | "EUR/USD"
  segment         String // "International" | "Channel Development"
  revenueImpact   Float  // $M (negative = headwind)
  operatingImpact Float  // $M
  avgRate         Float
  priorYearRate   Float
  hedgedRate      Float?

  company Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  period  FiscalPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([companyId, periodId, currencyPair])
  @@map("fx_impacts")
}

model LaborMetric {
  id                  Int    @id @default(autoincrement())
  companyId           Int
  periodId            Int
  region              String // "US - West" | "US - Northeast" | "China" etc.
  avgWageRate         Float  // $/hr
  turnoverRate        Float  // % annual
  hoursPerStore       Float  // weekly avg
  overtimePct         Float  // % of total hours
  trainingHours       Float  // per partner per quarter
  partnerSatisfaction Float? // score 0-100

  company Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  period  FiscalPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([companyId, periodId, region])
  @@map("labor_metrics")
}

model CustomerSatisfaction {
  id                   Int    @id @default(autoincrement())
  companyId            Int
  periodId             Int
  region               String
  npsScore             Float  // -100 to +100
  csatScore            Float  // 0-100
  waitTimeSatisfaction Float? // 0-100
  orderAccuracy        Float? // %
  sampleSize           Int?

  company Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  period  FiscalPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([companyId, periodId, region])
  @@map("customer_satisfaction")
}

model PromotionalCalendar {
  id              Int    @id @default(autoincrement())
  companyId       Int
  campaignName    String // "Pumpkin Spice Launch" | "Red Cup Season"
  startDate       String // ISO date
  endDate         String
  category        String // "seasonal" | "LTO" | "loyalty" | "value" | "brand"
  revenueImpact   Float? // $M estimated incremental
  transactionLift Float? // %
  ticketLift      Float? // %
  status          String // "planned" | "active" | "completed" | "cancelled"
  region          String @default("Global") // "North America" | "International" | "Global"

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, campaignName, startDate])
  @@map("promotional_calendar")
}

model StoreRenovation {
  id                         Int    @id @default(autoincrement())
  companyId                  Int
  renovationType             String // "Siren System" | "Store Remodel" | "Drive-Thru Enhancement" | "New Format"
  segment                    String // "North America" | "International"
  storesComplete             Int
  storesInProgress           Int
  storesPlanned              Int
  totalTarget                Int
  completionPct              Float
  avgCost                    Float  // $K per store
  avgRevenueUplift           Float? // % revenue increase post-renovation
  avgThroughputImprovement   Float? // % improvement
  quarterLabel               String // "Q2 FY26"

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, renovationType, segment, quarterLabel])
  @@map("store_renovations")
}

// =============================================================================
// AI CHAT — Persistent conversation threads
// =============================================================================

model ChatThread {
  id        String        @id @default(cuid())
  title     String        @default("New conversation")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]

  @@map("chat_threads")
}

model ChatMessage {
  id        String     @id @default(cuid())
  threadId  String
  role      String     // "user" | "assistant"
  content   String
  metadata  Json?      // model tier, tool results, etc.
  createdAt DateTime   @default(now())

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

# ============================================================
# Neon PostgreSQL — TWO URLs required for Vercel + Prisma
# ============================================================

# Pooled connection (pgbouncer) — used at RUNTIME for all queries
# Get from: neon.tech → Connect → Framework: Prisma → Pooled
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"

# Direct connection — used by prisma generate and migrations
# Get from: neon.tech → Connect → Direct connection (no -pooler in hostname)
DATABASE_URL_UNPOOLED="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Authentication
APP_PASSWORD="your-demo-password"
APP_SECRET="generate-a-random-64-char-hex-string"

# AI Chat (Anthropic Claude)
ANTHROPIC_API_KEY="sk-ant-..."
